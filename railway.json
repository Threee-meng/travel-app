{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build",
    "env": {
      "NODE_ENV": "production"
    }
  },
  "deploy": {
    "startCommand": "node deploy.js",
    "healthcheckPath": "/api/health",
    "numReplicas": 1
  }
}
